# Docker build context: used by training image (root) and data-gen image (docker/data-gen/)
# The data-gen build uses docker/data-gen/ as its own context, so these rules
# primarily affect the training image build from the project root.

Controller/
Simulator/
dataset/
docs/
hardware/
.git/
.github/
.pytest_cache/
.ruff_cache/
.venv/
wandb/

# Python cache
__pycache__/
*.pyc
*.pyo

# ROS catkin build artifacts
Simulator/build/
Simulator/devel/
Simulator/logs/
Simulator/.catkin_workspace
Simulator/.catkin_tools/

# Misc
.gitignore
.gitmodules
LICENSE
*.rst
*.md
*.gif
*.png
*.jpg
